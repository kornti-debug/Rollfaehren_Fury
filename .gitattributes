* text=auto

# Unity text assets
*.cs text eol=lf
*.shader text eol=lf
*.hlsl text eol=lf
*.cginc text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.meta text eol=lf
*.controller text eol=lf
*.anim text eol=lf
*.overrideController text eol=lf
*.physicMaterial text eol=lf
*.physicsMaterial2D text eol=lf
*.renderTexture text eol=lf
*.inputactions text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.py text eol=lf
*.yml text eol=lf
*.wproj text eol=lf
# Wwise work units are structured XML: never let git auto-merge them line-by-line
# (that silently produces invalid XML Wwise can't open). -merge forces a manual
# conflict instead. Prefer per-author/feature work units to avoid conflicts.
*.wwu text eol=lf -merge
*.plist text eol=lf

# Unity TerrainData assets are binary even when they use the .asset extension.
"Assets/New Terrain.asset" filter=lfs diff=lfs merge=lfs -text -eol

# Git hooks and shell scripts must stay LF (CRLF breaks the shebang)
.githooks/* text eol=lf
*.sh text eol=lf

# 3D assets
*.fbx filter=lfs diff=lfs merge=lfs -text
*.blend filter=lfs diff=lfs merge=lfs -text
*.obj filter=lfs diff=lfs merge=lfs -text
